generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Situation {
  RENTER
  OWNER
  STUDENT
  SELF_EMPLOYED
  EMPLOYED
}

enum Concern {
  HOUSING
  JOB_SECURITY
  SAVINGS
  DEBT
  RETIREMENT
}

enum Pillar {
  GLOBAL_ECONOMICS
  GEOPOLITICS_MONEY
  DEVELOPMENT_POLICY
  PERSONAL_FINANCE
}

enum Impact {
  HIGH
  MEDIUM
  LOW
}

model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  situation          Situation?
  concern            Concern?
  city               String?
  isPremium          Boolean     @default(false)
  onboardingComplete Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  accounts           Account[]
  sessions           Session[]
  questions          UserQuestion[]
  savedEvents        SavedEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EconEvent {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  summary         String
  fullExplanation String
  pillar          Pillar
  impact          Impact
  published       Boolean    @default(false)
  publishedAt     DateTime
  youtubeUrl      String?
  sources         String[]

  savedBy         SavedEvent[]
}

model UserQuestion {
  id        String   @id @default(cuid())
  userId    String
  question  String
  answer    String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedEvent {
  id      String   @id @default(cuid())
  userId  String
  eventId String
  savedAt DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   EconEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}
