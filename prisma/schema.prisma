generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Situation {
  RENTER
  OWNER
  STUDENT
  SELF_EMPLOYED
  EMPLOYED
}

enum HousingStatus {
  RENTER
  HOMEOWNER
  LIVING_WITH_OTHERS
  OTHER_HOUSING
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED_LOOKING
  UNEMPLOYED_NOT_LOOKING
  STUDENT
  RETIRED
}

enum Concern {
  HOUSING
  JOB_SECURITY
  SAVINGS
  DEBT
  RETIREMENT
}

enum LifeStage {
  EARLY_CAREER
  MID_CAREER
  PRE_RETIREMENT
  RETIRED
}

enum Industry {
  HEALTHCARE
  TECHNOLOGY
  GOVERNMENT
  EDUCATION
  RETAIL_SERVICE
  CONSTRUCTION_TRADES
  FINANCE_BANKING
  LOGISTICS_TRANSPORTATION
  ENERGY
  AGRICULTURE
  CREATIVE_MEDIA
  RESEARCH_NONPROFIT
  OTHER
  NOT_APPLICABLE
}

enum Pillar {
  GLOBAL_ECONOMICS
  GEOPOLITICS_MONEY
  DEVELOPMENT_POLICY
  PERSONAL_FINANCE
}

enum Impact {
  HIGH
  MEDIUM
  LOW
}

enum Tier {
  GLOBAL
  NATIONAL
  REGIONAL
}

model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  situation          Situation?
  housingStatus      HousingStatus?
  employmentStatus   EmploymentStatus?
  concern            Concern?
  city               String?
  lifeStage          LifeStage?
  debtTypes          String[]
  industry           Industry?
  language           String      @default("en")
  isPremium          Boolean     @default(false)
  onboardingComplete Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  accounts           Account[]
  sessions           Session[]
  questions          UserQuestion[]
  savedEvents        SavedEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model EconEvent {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  summary         String
  fullExplanation String
  pillar          Pillar
  impact          Impact
  tier            Tier       @default(NATIONAL)
  region          String?
  newsUrl         String?
  newsSource      String?
  isNews          Boolean    @default(false)
  published       Boolean    @default(false)
  publishedAt     DateTime
  youtubeUrl      String?
  sources         String[]

  savedBy         SavedEvent[]
}

model NewsCache {
  id              String   @id @default(cuid())
  title           String
  summary         String
  fullExplanation String
  url             String   @unique
  source          String
  contentType     String   @default("News")
  publishedAt     DateTime
  pillar          Pillar
  impact          Impact   @default(MEDIUM)
  tier            Tier
  region          String?
  createdAt       DateTime @default(now())
}

model UserQuestion {
  id        String   @id @default(cuid())
  userId    String
  question  String
  answer    String
  flagged   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedEvent {
  id      String   @id @default(cuid())
  userId  String
  eventId String
  savedAt DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   EconEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model EconomicIndicator {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  date      String
  fetchedAt DateTime @default(now())
}
