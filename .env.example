# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/simple_economics?schema=public"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-char-string"

# Your app's public URL (no trailing slash)
# Development: http://localhost:3000
# Production:  https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email (Magic Link) ──────────────────────────────────────────────────────
# SMTP server for sending sign-in emails
# Resend: smtp.resend.com:465 | SendGrid: smtp.sendgrid.net:587
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="your-smtp-password"
EMAIL_FROM="Simple Economics <noreply@yourdomain.com>"

# ─── Anthropic (Ask the Economist + News AI) ─────────────────────────────────
# Create at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-api-key"

# ─── NewsAPI (news feed fetching) ────────────────────────────────────────────
# Free tier: 100 requests/day, 6-hour cache keeps usage well within limits
# Create at: https://newsapi.org/register
NEWSAPI_KEY="your-newsapi-key"
